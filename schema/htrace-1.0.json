{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/CorvinLabs/CorvinLogs/schema/htrace-1.0.json",
  "title": "HealingTrace v1",
  "description": "CorvinOS HealingTrace v1 — scrubbed, PII-free self-healing telemetry record.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "corvin_version", "platform", "python",
    "error_fingerprint", "error_type", "error_module_ns", "error_function",
    "error_line", "error_template", "stack_frames", "event_sequence",
    "heal_action", "heal_outcome", "config_profile_hash",
    "tenant_shape", "ts_day", "consent_act_id", "instance_token"
  ],
  "properties": {
    "schema":             { "type": "string", "const": "htrace/1" },
    "corvin_version":     { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+.*$" },
    "platform":           { "type": "string", "pattern": "^(linux|darwin|windows)/[a-z0-9_]+$" },
    "python":             { "type": "string", "pattern": "^[0-9]+\\.[0-9]+$" },
    "error_fingerprint":  { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "error_type":         { "type": "string", "maxLength": 120 },
    "error_module_ns":    { "type": "string", "maxLength": 120 },
    "error_function":     { "type": "string", "maxLength": 60 },
    "error_line":         { "type": "integer", "minimum": 0 },
    "error_template":     { "type": "string", "maxLength": 200 },
    "stack_frames": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ns", "fn", "ln"],
        "properties": {
          "ns": { "type": "string", "maxLength": 60 },
          "fn": { "type": "string", "maxLength": 60 },
          "ln": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "event_sequence": {
      "type": "array",
      "maxItems": 10,
      "items": { "type": "string", "maxLength": 80 }
    },
    "heal_action":          { "type": "string", "maxLength": 80 },
    "heal_outcome":         { "type": "string", "enum": ["success", "failure", "skipped"] },
    "config_profile_hash":  { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "tenant_shape":         { "type": "string", "enum": ["single"] },
    "ts_day":               { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "consent_act_id":       { "type": "string", "maxLength": 64 },
    "instance_token":       { "type": "string", "maxLength": 64 }
  }
}
